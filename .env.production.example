t# ============================================
# TinAdmin SaaS Platform - Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in your production values
# DO NOT commit .env.production to version control
# 
# For Vercel deployment, set these in:
# Vercel Dashboard → Project → Settings → Environment Variables
# ============================================

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from your Supabase project dashboard:
# Settings → API → Project URL and API keys

# Supabase Project URL (Production)
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co

# Supabase Anonymous Key (Public, safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key-here

# Supabase Service Role Key (Secret, server-side only)
# ⚠️ CRITICAL: NEVER expose this in client-side code
# Required for admin operations and bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key-here

# ============================================
# Stripe Configuration (Required for Billing)
# ============================================
# Get these from your Stripe dashboard:
# Developers → API keys → Live mode

# Stripe Publishable Key (Public, safe for client-side)
# Production: pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-production-publishable-key-here

# Stripe Secret Key (Secret, server-side only)
# ⚠️ CRITICAL: NEVER expose this in client-side code
# Production: sk_live_...
STRIPE_SECRET_KEY=sk_live_your-production-secret-key-here

# Stripe Webhook Secret (Required for webhook verification)
# Get this from: Developers → Webhooks → Add endpoint → Signing secret
# Use the LIVE webhook endpoint secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your-production-webhook-secret-here

# ============================================
# Application Configuration
# ============================================

# Site URL (used for redirects, email links, etc.)
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Application Name (displayed in UI, emails, etc.)
NEXT_PUBLIC_APP_NAME=Your SaaS Platform

# Platform Admin Email (default admin user email)
# Used for initial platform admin creation
NEXT_PUBLIC_PLATFORM_ADMIN_EMAIL=admin@yourcompany.com

# ============================================
# Node Environment
# ============================================
# Set to production for production deployments
NODE_ENV=production

# ============================================
# Email Configuration
# ============================================

# Default "From" email address for transactional emails
# Must be verified with your email provider
EMAIL_FROM=noreply@yourdomain.com

# Email Provider (resend | sendgrid | amazon_ses | brevo | postmark)
# Default: resend
EMAIL_PROVIDER=resend

# Email Fallback Provider (optional, used if primary fails)
EMAIL_FALLBACK_PROVIDER=

# ============================================
# Resend Email Provider (Default)
# ============================================
# Get API key from: https://resend.com/api-keys
# Use production API key (starts with re_)
RESEND_API_KEY=re_your-production-resend-api-key-here
RESEND_SANDBOX=false

# ============================================
# SendGrid Email Provider (Alternative)
# ============================================
# Get API key from: https://app.sendgrid.com/settings/api_keys
# Use production API key
SENDGRID_API_KEY=SG.your-production-sendgrid-api-key-here
SENDGRID_SANDBOX=false

# ============================================
# Amazon SES Email Provider (Alternative)
# ============================================
# Get credentials from AWS IAM Console
AWS_SES_ACCESS_KEY_ID=your-production-aws-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-production-aws-secret-access-key
AWS_SES_REGION=us-east-1

# ============================================
# Brevo Email Provider (Alternative)
# ============================================
# Get API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-production-brevo-api-key-here

# ============================================
# Postmark Email Provider (Alternative)
# ============================================
# Get API key from: https://account.postmarkapp.com/servers
POSTMARK_API_KEY=your-production-postmark-api-key-here

# ============================================
# Telephony (Telnyx)
# ============================================
# Optional fallback if no tenant/system Telnyx integration is configured
# Get from: Telnyx Mission Control → API Keys
TELNYX_API_KEY=your-production-telnyx-api-key-here

# Telnyx Webhook Secret (for webhook signature verification)
# Get from: Telnyx Mission Control → Messaging → Messaging Profiles → [Your Profile] → Webhook Settings
TELNYX_WEBHOOK_SECRET=your-production-telnyx-webhook-secret-here

# ============================================
# AI (Vercel AI Gateway / OpenAI)
# ============================================
# Recommended: use the System Admin → API Configuration UI to store system-wide AI Gateway keys.
# These env vars are supported as fallbacks:

# Vercel AI Gateway API Key (if using Vercel AI Gateway)
AI_GATEWAY_API_KEY=your-production-ai-gateway-api-key-here

# Optional alternative auth for Vercel AI Gateway
VERCEL_OIDC_TOKEN=your-production-vercel-oidc-token-here

# Direct OpenAI API Key (used if no gateway key is configured)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-production-openai-api-key-here

# ============================================
# Builder.io Visual CMS
# ============================================
# Get your API key from: https://builder.io/account/space
# Required for Builder.io visual editing
NEXT_PUBLIC_BUILDER_API_KEY=your-production-builder-io-api-key-here

# ============================================
# Integration Credentials Encryption
# ============================================
# 32-byte key (base64 or hex) used to encrypt integration_configs.credentials
# Generate a secure random key:
#   openssl rand -base64 32
#   OR
#   openssl rand -hex 32
# ⚠️ CRITICAL: Must be the same across all environments that need to decrypt existing credentials
# ⚠️ CRITICAL: Store securely and rotate periodically
INTEGRATION_CREDENTIALS_KEY=your-32-byte-base64-or-hex-encryption-key-here

# ============================================
# Security Best Practices
# ============================================
# 1. Use strong, unique values for all secrets
# 2. Rotate keys periodically (especially INTEGRATION_CREDENTIALS_KEY)
# 3. Never commit .env.production to version control
# 4. Use different values for development, staging, and production
# 5. Enable 2FA on all service accounts (Supabase, Stripe, etc.)
# 6. Restrict API keys to minimum required permissions
# 7. Monitor API usage and set up alerts for unusual activity
# 8. Use environment-specific webhook secrets
# 9. Regularly audit and review access logs
# 10. Keep dependencies updated to patch security vulnerabilities

# ============================================
# Vercel-Specific Notes
# ============================================
# When deploying to Vercel:
# 1. Set all variables in Vercel Dashboard → Project → Settings → Environment Variables
# 2. Select "Production" environment for production deployments
# 3. Use "Preview" environment for staging/PR previews
# 4. Vercel automatically sets NODE_ENV=production for production deployments
# 5. Use Vercel's built-in environment variable encryption
# 6. Consider using Vercel Secrets for sensitive values

# ============================================
# Required Variables Checklist
# ============================================
# ✅ NEXT_PUBLIC_SUPABASE_URL
# ✅ NEXT_PUBLIC_SUPABASE_ANON_KEY
# ✅ SUPABASE_SERVICE_ROLE_KEY
# ✅ NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
# ✅ STRIPE_SECRET_KEY
# ✅ STRIPE_WEBHOOK_SECRET
# ✅ NEXT_PUBLIC_SITE_URL
# ✅ EMAIL_FROM
# ✅ EMAIL_PROVIDER (and corresponding API key)
# ✅ INTEGRATION_CREDENTIALS_KEY
# 
# Optional but Recommended:
# ⚪ TELNYX_API_KEY (if using Telnyx)
# ⚪ TELNYX_WEBHOOK_SECRET (if using Telnyx webhooks)
# ⚪ AI_GATEWAY_API_KEY or OPENAI_API_KEY (if using AI features)
# ⚪ NEXT_PUBLIC_PLATFORM_ADMIN_EMAIL (for initial admin setup)
