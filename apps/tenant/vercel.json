{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd ../.. && corepack enable && pnpm install",
  "buildCommand": "cd ../.. && TURBO_FORCE=true pnpm turbo run build --filter=@tinadmin/tenant",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/campaigns/process",
      "schedule": "*/2 * * * *"
    }
  ]
}
